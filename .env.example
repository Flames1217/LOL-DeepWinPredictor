# Server
HOST=0.0.0.0
PORT=7777

# Optional site visit statistics. Leave empty to disable database writes.
MYSQL_URL=mysql://user:password@127.0.0.1:3306/lol_deepwinpredictor?charset=utf8mb4

# Optional remote model file. Supports HTTPS direct links, WebDAV HTTPS links,
# public s3://bucket/key links, and S3/R2/OSS presigned HTTPS links.
MODEL_URL=

# Optional AI provider for streamed analysis and schedule/prediction explanation.
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Frontend/backend split deployment.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:7777

# Optional proxy for live source requests.
PROXIES=
