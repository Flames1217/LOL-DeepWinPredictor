# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_CHARSET=utf8mb4
MYSQL_DATABASE=your_database

# 代理配置
PROXY="{'http': 'http://127.0.0.1:7890', 'https': 'http://127.0.0.1:7890'}"

# Model loading. Local MODEL_PATH is used first; if it is missing, the backend
# downloads MODEL_URL/S3_MODEL_URL/WEBDAV_MODEL_URL into MODEL_CACHE_DIR.
# For S3/R2/OSS, use a public or presigned HTTPS URL. For WebDAV, use a direct
# file URL that supports GET.
MODEL_PATH=static/saved_model/BILSTM_Att.pt
MODEL_URL=
S3_MODEL_URL=
WEBDAV_MODEL_URL=
MODEL_CACHE_DIR=
MODEL_FILENAME=BILSTM_Att.pt
MODEL_SHA256=

# Optional Basic Auth for WebDAV or protected HTTP model URLs.
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
MODEL_BASIC_AUTH_USER=
MODEL_BASIC_AUTH_PASSWORD=

# Frontend/backend split deployment. For a Vercel frontend with an external
# FastAPI backend, set this to the backend origin, e.g. https://api.example.com.
NEXT_PUBLIC_API_BASE_URL=
